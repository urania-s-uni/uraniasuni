      document.getElementById('pf').style.width = Math.min(on.size / 8 * 100, 100) + '%';
      document.getElementById('rbtn').disabled = on.size === 0;
    };
    list.appendChild(el);
  });

  function showResult() {
    const scores = {};
    on.forEach(i => {
      items[i].types.forEach(t => {
        scores[t] = (scores[t] || 0) + 1;
      });
    });

    const top = Object.entries(scores).sort((a, b) => b[1] - a[1])[0][0];
    const d = types[top];

    document.getElementById('rzone').textContent = d.zone;
    document.getElementById('rtype').textContent = top;
    document.getElementById('rtag').textContent = `"${d.tag}"`;
    document.getElementById('rdesc').textContent = d.desc;
    document.getElementById('truthBody').textContent = d.truth;
    document.getElementById('warnBody').textContent = d.warn;
    document.getElementById('rch').textContent = d.ch;
    document.getElementById('rq').textContent = d.q;

    document.getElementById('quiz').style.display = 'none';
    document.getElementById('result').style.display = 'block';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function goToFunding() {
    window.open(FUNDING_URL, '_blank');
  }

  function copyR(e) {
    const t = document.getElementById('rtype').textContent;
    const d = types[t];
    const text = `[청춘℃ 유형 진단]
나는 ${t}
"${d.tag}"

문제는 의지가 아니었다.
구조였다.

${d.q}

청춘℃ 끓기 직전의 온도`;

    navigator.clipboard.writeText(text).then(() => {
      const btn = e.currentTarget;
      const original = btn.innerHTML;
      btn.innerHTML = '✓ 복사됨';
      setTimeout(() => {
        btn.innerHTML = original;
      }, 1800);
    });
  }

  function shareR(e) {
    const t = document.getElementById('rtype').textContent;
    const d = types[t];
    const shareText = `나는 ${t}
"${d.tag}"

이거, 내 얘기였다.
문제는 의지가 아니라 구조였다.

청춘℃ 끓기 직전의 온도`;

    if (navigator.share) {
      navigator.share({
        title: '청춘℃ 유형 진단',
        text: shareText,
        url: FUNDING_URL
      });
    } else {
      copyR(e);
    }
  }

  function retry() {
    on.clear();
    document.querySelectorAll('.item').forEach(el => el.classList.remove('on'));
    document.getElementById('pf').style.width = '0%';
    document.getElementById('rbtn').disabled = true;
    document.getElementById('result').style.display = 'none';
    document.getElementById('quiz').style.display = 'block';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
</script>
</body>
</html>
