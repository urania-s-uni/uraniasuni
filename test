<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>청춘℃ 유형 진단 — 당신은 지금 몇 도입니까</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: #f7f5f2;
    color: #1a1a1a;
    font-family: 'Apple SD Gothic Neo', 'Malgun Gothic', 'Noto Sans KR', sans-serif;
    min-height: 100vh;
    line-height: 1.6;
  }
  .wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: 48px 20px 100px;
  }

  .hd {
    text-align: center;
    margin-bottom: 40px;
    padding-bottom: 28px;
    border-bottom: 1px solid #e0dbd4;
  }
  .hd-tag {
    font-size: 11px;
    letter-spacing: .22em;
    color: #c8440a;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .hd h1 {
    font-size: clamp(24px, 5vw, 34px);
    font-weight: 800;
    line-height: 1.35;
    margin-bottom: 14px;
    color: #1a1a1a;
  }
  .hd h1 em {
    color: #c8440a;
    font-style: normal;
  }
  .hd p {
    font-size: 14px;
    color: #777;
    line-height: 1.8;
  }

  .prog {
    height: 2px;
    background: #e0dbd4;
    margin-bottom: 28px;
    border-radius: 1px;
    overflow: hidden;
  }
  .prog-fill {
    height: 100%;
    background: #c8440a;
    transition: width .3s;
  }

  .sec-label {
    font-size: 11px;
    letter-spacing: .18em;
    color: #aaa;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 28px;
  }
  .item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 16px;
    background: #fff;
    border: 1px solid #e8e3dc;
    border-radius: 10px;
    cursor: pointer;
    transition: all .15s;
    user-select: none;
  }
  .item:hover {
    border-color: #d0c9c0;
    background: #fdfcfb;
  }
  .item.on {
    border-color: #c8440a;
    background: #fef4f0;
  }

  .box {
    width: 18px;
    height: 18px;
    min-width: 18px;
    border: 1.5px solid #ccc;
    border-radius: 3px;
    margin-top: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .15s;
    flex-shrink: 0;
  }
  .item.on .box {
    background: #c8440a;
    border-color: #c8440a;
  }
  .chk {
    opacity: 0;
    transition: opacity .15s;
  }
  .item.on .chk {
    opacity: 1;
  }

  .item-title {
    font-size: 14px;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 4px;
  }
  .item-body {
    font-size: 13px;
    line-height: 1.65;
    color: #666;
  }

  .btn {
    width: 100%;
    padding: 17px;
    background: #c8440a;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 800;
    cursor: pointer;
    transition: all .15s;
    margin-bottom: 12px;
    letter-spacing: .01em;
  }
  .btn:hover {
    background: #e8650a;
    transform: translateY(-1px);
  }
  .btn:disabled {
    background: #ddd;
    color: #aaa;
    cursor: not-allowed;
    transform: none;
  }

  .btn-sub {
    width: 100%;
    padding: 17px;
    background: #1a1a1a;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 800;
    cursor: pointer;
    transition: all .15s;
    margin-bottom: 12px;
    letter-spacing: .01em;
  }
  .btn-sub:hover {
    background: #333;
    transform: translateY(-1px);
  }

  .hint {
    text-align: center;
    font-size: 12px;
    color: #aaa;
  }

  .result { display: none; }

  .hero-judge {
    background: linear-gradient(180deg, #fff 0%, #fef4f0 100%);
    border: 1px solid rgba(200,68,10,.18);
    border-radius: 16px;
    padding: 28px 22px;
    margin-bottom: 20px;
    box-shadow: 0 4px 18px rgba(0,0,0,.04);
  }
  .judge-label {
    font-size: 11px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: #c8440a;
    margin-bottom: 12px;
  }
  .judge-title {
    font-size: clamp(28px, 6vw, 42px);
    line-height: 1.25;
    font-weight: 900;
    color: #1a1a1a;
    margin-bottom: 10px;
  }
  .judge-desc {
    font-size: 14px;
    color: #666;
    line-height: 1.8;
  }

  .rcard {
    background: #fff;
    border: 1px solid #e8e3dc;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 18px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
  }
  .rhead {
    padding: 28px 24px 22px;
    border-bottom: 1px solid #e8e3dc;
    background: #fdfcfb;
  }
  .rzone {
    font-size: 11px;
    letter-spacing: .22em;
    color: #c8440a;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .rtype {
    font-size: clamp(24px, 5.5vw, 36px);
    font-weight: 900;
    margin-bottom: 8px;
    color: #1a1a1a;
  }
  .rtag {
    font-size: 14px;
    color: #888;
    font-style: italic;
  }
  .rbody {
    padding: 24px;
  }
  .rdesc {
    font-size: 14px;
    line-height: 1.95;
    color: #555;
    white-space: pre-line;
  }

  .panel {
    background: #fff;
    border: 1px solid #e8e3dc;
    border-radius: 14px;
    padding: 20px;
    margin-bottom: 14px;
  }
  .panel.warn {
    background: #fff8f5;
    border-color: rgba(200,68,10,.22);
  }
  .panel.solve {
    background: #fdfcfb;
  }
  .panel-label {
    font-size: 10px;
    letter-spacing: .18em;
    color: #c8440a;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .panel-title {
    font-size: 18px;
    font-weight: 800;
    line-height: 1.5;
    margin-bottom: 10px;
    color: #1a1a1a;
  }
  .panel-body {
    font-size: 14px;
    color: #555;
    line-height: 1.9;
    white-space: pre-line;
  }
  .panel-body strong {
    color: #1a1a1a;
  }

  .chapter-box {
    padding: 18px;
    background: #fef4f0;
    border: 1px solid rgba(200,68,10,.2);
    border-radius: 10px;
    margin-bottom: 18px;
  }
  .chapter-label {
    font-size: 10px;
    letter-spacing: .18em;
    color: #c8440a;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .chapter-title {
    font-size: 15px;
    font-weight: 800;
    margin-bottom: 6px;
    color: #1a1a1a;
  }
  .chapter-q {
    font-size: 13px;
    color: #888;
    font-style: italic;
    line-height: 1.7;
  }

  .cta-box {
    background: #1a1a1a;
    color: #fff;
    border-radius: 16px;
    padding: 24px 20px;
    margin: 22px 0 18px;
  }
  .cta-label {
    font-size: 10px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: rgba(255,255,255,.65);
    margin-bottom: 10px;
  }
  .cta-title {
    font-size: 22px;
    line-height: 1.5;
    font-weight: 900;
    margin-bottom: 10px;
  }
  .cta-body {
    font-size: 14px;
    line-height: 1.9;
    color: rgba(255,255,255,.82);
    margin-bottom: 16px;
  }

  .share-row {
    display: flex;
    gap: 10px;
    margin-bottom: 14px;
  }
  .sbtn {
    flex: 1;
    padding: 14px;
    border: 1px solid #e8e3dc;
    background: #fff;
    color: #1a1a1a;
    border-radius: 10px;
    font-size: 13px;
    cursor: pointer;
    transition: all .15s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: inherit;
  }
  .sbtn:hover {
    border-color: #c8440a;
    color: #c8440a;
  }

  .rbtn {
    width: 100%;
    padding: 14px;
    background: transparent;
    border: 1px solid #e8e3dc;
    color: #888;
    border-radius: 10px;
    font-size: 13px;
    cursor: pointer;
    transition: all .15s;
    font-family: inherit;
  }
  .rbtn:hover {
    border-color: #ccc;
    color: #666;
  }

  .foot-note {
    text-align: center;
    font-size: 12px;
    color: #999;
    margin-top: 8px;
    line-height: 1.7;
  }

  @media (max-width: 560px) {
    .share-row {
      flex-direction: column;
    }
    .wrap {
      padding: 32px 16px 80px;
    }
  }
</style>
</head>
<body>
<div class="wrap">

  <!-- QUIZ -->
  <div id="quiz">
    <div class="hd">
      <div class="hd-tag">청춘℃ 유형 진단</div>
      <h1>당신은 지금<br><em>몇 도</em>입니까</h1>
      <p>
        해당되는 것을 전부 체크하라.<br>
        당신이 왜 안 바뀌는지 드러난다.
      </p>
    </div>

    <div class="prog">
      <div class="prog-fill" id="pf" style="width:0%"></div>
    </div>

    <div class="sec-label">나에게 해당되는 것을 전부 골라라</div>
    <div class="list" id="list"></div>

    <button class="btn" id="rbtn" disabled onclick="showResult()">
      내가 왜 안 바뀌는지 확인하기
    </button>
    <p class="hint">1개 이상 체크하면 결과가 나옵니다</p>
  </div>

  <!-- RESULT -->
  <div class="result" id="result">

    <div class="hero-judge">
      <div class="judge-label">진단 결과</div>
      <div class="judge-title">당신은 지금,<br>끓지 않는 상태다</div>
      <div class="judge-desc">
        실패한 것이 아니다. 아직 구조가 바뀌지 않은 것이다.
      </div>
    </div>

    <div class="rcard">
      <div class="rhead">
        <div class="rzone" id="rzone"></div>
        <div class="rtype" id="rtype"></div>
        <div class="rtag" id="rtag"></div>
      </div>
      <div class="rbody">
        <div class="rdesc" id="rdesc"></div>
      </div>
    </div>

    <div class="panel">
      <div class="panel-label">불편한 진실</div>
      <div class="panel-title" id="truthTitle">
        문제는 의지가 아니다.<br>에너지가 잘못 쓰이고 있다.
      </div>
      <div class="panel-body" id="truthBody"></div>
    </div>

    <div class="panel warn">
      <div class="panel-label">경고</div>
      <div class="panel-title" id="warnTitle">
        이 상태로 계속 가면,<br>더 열심히 하는데도 더 지치게 된다.
      </div>
      <div class="panel-body" id="warnBody"></div>
    </div>

    <div class="chapter-box">
      <div class="chapter-label">당신을 위한 챕터</div>
      <div class="chapter-title" id="rch"></div>
      <div class="chapter-q" id="rq"></div>
    </div>

    <div class="panel solve">
      <div class="panel-label">해결 방향</div>
      <div class="panel-title">
        이건 당신의 문제가 아니다.<br>구조 문제다.
      </div>
      <div class="panel-body" id="solveBody">
        구조는 의지로 못 바꾼다.
        <strong>설계로 바꿔야 한다.</strong>

        그래서 이 책은 당신을 위로하지 않는다.
        대신 30일 동안 당신이 작동하는 방식을 다시 설계한다.
      </div>
    </div>

    <div class="cta-box">
      <div class="cta-label">next step</div>
      <div class="cta-title">지금 상태를 알았는데<br>아무것도 안 하면 더 손해다</div>
      <div class="cta-body">
        열심히 하는데도 안 바뀌는 이유를 이미 확인했다.
        이제 필요한 건 더 많은 의지가 아니라,
        <strong>당신을 끓게 만드는 구조</strong>다.
      </div>
      <button class="btn" onclick="goToFunding()">내 상태를 바꾸는 구조 보기</button>
      <button class="btn-sub" onclick="goToFunding()">30일 OS 설치하기</button>
      <div class="foot-note">버튼 링크는 와디즈 상세페이지 주소로 바꿔서 사용하세요.</div>
    </div>

    <div class="share-row">
      <button class="sbtn" onclick="copyR(event)">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="9" y="9" width="13" height="13" rx="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        결과 복사
      </button>
      <button class="sbtn" onclick="shareR(event)">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="18" cy="5" r="3"></circle>
          <circle cx="6" cy="12" r="3"></circle>
          <circle cx="18" cy="19" r="3"></circle>
          <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
          <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
        </svg>
        공유하기
      </button>
    </div>

    <button class="rbtn" onclick="retry()">↺ 다시 진단하기</button>
  </div>
</div>

<script>
  // 와디즈 상세페이지 링크로 교체
  const FUNDING_URL = "https://www.wadiz.kr";

  const items = [
    { t:"도파민 좀비", b:"숏폼을 보기 시작하면 정신 차렸을 때 30분이 사라져 있다.", types:["공회전형","기생부하형"] },
    { t:"장비병", b:"시작하기 전에 장비나 책부터 산다. 제대로 쓴 적은 거의 없다.", types:["과적형"] },
    { t:"완벽주의 핑계", b:"제대로 할 거 아니면 안 하는 게 낫다고 생각한다. 사실은 시작이 두려운 것이다.", types:["과적형","대포형"] },
    { t:"아가리 파이터", b:"나 이거 할 거야라고 말하지만 실제 결과물은 0이다.", types:["공회전형","활성화에너지 미달형"] },
    { t:"작심삼일", b:"새해 목표, 월초 계획. 3일 이상 지속된 루틴이 지금 하나도 없다.", types:["활성화에너지 미달형"] },
    { t:"학습 중독", b:"강의와 책은 열심히 듣는다. 듣는 순간의 고양감만 즐길 뿐 삶에 적용한 건 없다.", types:["과적형","공회전형"] },
    { t:"알림 지옥", b:"카카오톡, 앱 푸시에 빨간 숫자가 99+ 떠 있지만 무감각하다.", types:["기생부하형"] },
    { t:"멀티태스킹의 덫", b:"밥 먹으며 유튜브 보고, 일하며 카톡한다. 산만한 상태가 기본값이다.", types:["공회전형","감속재형"] },
    { t:"만성 피로", b:"자고 일어났을 때 개운하다보다 더 자고 싶다가 지배적이다.", types:["기생부하형"] },
    { t:"비교 지옥", b:"SNS 속 타인의 삶과 나의 현실을 비교하며 스스로 비참해지는 감정이 자주 든다.", types:["열평형형"] },
    { t:"결정 장애", b:"점심 메뉴부터 진로까지, 선택하는 데 과도한 에너지를 쓰고 결국 남의 의견을 따른다.", types:["과적형","감속재형"] },
    { t:"벼락치기 의존", b:"마감이 코앞에 닥쳐 심장이 쫄깃해져야만 비로소 일에 착수한다.", types:["활성화에너지 미달형"] },
    { t:"만성 지각", b:"약속 시간에 5~10분씩 늦으며 거의 다 왔어라고 말한다.", types:["미루기형"] },
    { t:"과거 집착", b:"그때 그걸 했어야 했는데. 이미 지나간 일을 계속 되감기한다.", types:["열평형형","미루기형"] },
    { t:"걱정의 늪", b:"일어나지 않은 일에 대한 걱정 때문에 정작 지금 해야 할 일에 집중을 못 한다.", types:["감속재형"] },
    { t:"요행 대기", b:"언젠가 기회가 올 거라고 생각한다. 한 방이 있을 것 같다. 근데 준비는 안 하고 있다.", types:["요행형"] },
    { t:"혼자 버팀", b:"도움을 받으면 빚지는 것 같다. 연결하면 더 빠를 것 같은데 혼자 버티고 있다.", types:["고립계형"] },
    { t:"나중에 하면 돼", b:"조금 더 여유가 생기면 시작하려고 한다. 그 나중이 온 적이 없다.", types:["미루기형"] },
    { t:"조용한 공포", b:"분명히 하고 있는데 달라진 게 없다. 이게 맞는 건지 확인할 방법이 없어서 그냥 하고 있다.", types:["임계점형","잠열 구간형"] },
    { t:"중간 점검 중독", b:"잘 되고 있는지 자꾸 확인하고 싶어진다. 확인할 때마다 불안해지는데 또 확인한다.", types:["감속재형","임계점형"] },
    { t:"비교 자동화", b:"SNS를 안 보려고 해도 결국 본다. 보고 나면 내가 너무 느린 것 같다.", types:["임계점형","열평형형"] },
    { t:"멈추면 무너질 것 같은 느낌", b:"쉬면 다 리셋될 것 같아서 쉬지 못한다. 쉬는 동안에도 뭔가 해야 할 것 같다.", types:["연쇄반응형","잠열 구간형"] },
    { t:"여기까지 왔는데", b:"포기하자니 지금까지 한 게 아깝고, 계속하자니 확신이 없다. 그래서 그냥 하고 있다.", types:["임계점형","잠열 구간형"] },
    { t:"성공 공포증", b:"뭔가 되고 있는데 언제 다시 멈출지 모른다는 생각이 먼저 든다.", types:["연쇄반응형"] },
    { t:"가속 불안", b:"잘 되고 있는데 오히려 예전보다 더 긴장된다. 잘 될수록 잃을 게 많아지는 것 같다.", types:["연쇄반응형"] }
  ];

